---
import '../styles/site.css';
const siteName = "Alfies Pet Services";
const id = "P2462";
const phone = "0161 432 8807";
const mobile = "07902 384948";
const email = "Alfiespetservices@sky.com";
const address = "38 Sunnybank Avenue, Heaton Mersey, Stockport SK4 3PR";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dog Walking | Dog Boarding | Doggie Day Care | Stockport | Alfies Pet Services</title>
  <meta name="description" content="Alfies Pet Services offer dog walking, dog boarding and doggie daycare in Stockport and the 4 Heatons. Call us on 0161 432 8807." />
  <link rel="icon" href="/favicon.ico" />
</head>
<body>

  <!-- Preview Banner -->
    <div style="background:#B45309;color:white;padding:10px 16px;text-align:center;font-size:14px;position:sticky;top:0;z-index:50"><div style="max-width:56rem;margin:0 auto;display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap"><span>Preview redesign for <strong>Alfies Pet Services</strong></span><a href="https://biscuitweb.co.uk/activate?id=P2462&amp;name=Alfies%20Pet%20Services" style="display:inline-flex;align-items:center;padding:4px 16px;background:white;color:#B45309;font-weight:700;font-size:12px;border-radius:9999px;text-decoration:none">Like it? Just £20/month</a></div></div>

    </section>

  <!-- Trust Badges -->
  <section class="bg-[#12283C] text-white py-6">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center text-sm">
        <div class="flex flex-col items-center gap-1">
          <span class="text-2xl">🏛️</span>
          <span class="font-semibold">Council Licensed</span>
          <span class="text-white/70 text-xs">Stockport Council</span>
        </div>
        <div class="flex flex-col items-center gap-1">
          <span class="text-2xl">🛡️</span>
          <span class="font-semibold">Fully Insured</span>
          <span class="text-white/70 text-xs">Peace of mind</span>
        </div>
        <div class="flex flex-col items-center gap-1">
          <span class="text-2xl">✅</span>
          <span class="font-semibold">CRB Checked</span>
          <span class="text-white/70 text-xs">Trusted &amp; vetted</span>
        </div>
        <div class="flex flex-col items-center gap-1">
          <span class="text-2xl">📍</span>
          <span class="font-semibold">Local Service</span>
          <span class="text-white/70 text-xs">The 4 Heatons</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-16 px-4 max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-800 font-display text-[#12283C] mb-3">What I Offer</h2>
      <p class="text-[#0B1824] text-lg max-w-xl mx-auto">Friendly, flexible pet services tailored to you and your dog in the 4 Heatons and surrounding areas.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-[#DBDFE2] hover:shadow-md transition-shadow">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/P2462/images/6263212-orig.jpg" alt="Dog walking in Stockport" loading="lazy" width="640" height="480" class="w-full h-full object-cover" />
        </div>
        <div class="p-6">
          <h3 class="text-xl font-800 font-display text-[#12283C] mb-2">🐕 Dog Walking</h3>
          <p class="text-[#0B1824] text-sm mb-4">Competitive rates for group or solo walks, tailored to your dog's needs. Currently very limited availability.</p>
          <div class="flex items-center justify-between">
            <span class="text-[#12283C] font-semibold text-sm">From £10.00/walk</span>
            <a href="/P2462/dog-walking-html" class="text-[#12283C] font-semibold text-sm underline hover:text-yellow-600">Learn more</a>
          </div>
        </div>
      </div>
      <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-[#DBDFE2] hover:shadow-md transition-shadow">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/P2462/images/5327550-orig.jpg" alt="Doggie day care in Stockport" loading="lazy" width="640" height="480" class="w-full h-full object-cover" />
        </div>
        <div class="p-6">
          <h3 class="text-xl font-800 font-display text-[#12283C] mb-2">🏠 Doggie Day Care</h3>
          <p class="text-[#0B1824] text-sm mb-4">For when your dog needs more than a daily walk. Currently very limited availability, please contact us to check.</p>
          <div class="flex items-center justify-between">
            <span class="text-[#12283C] font-semibold text-sm">Contact for availability</span>
            <a href="/P2462/doggie-day-care-html" class="text-[#12283C] font-semibold text-sm underline hover:text-yellow-600">Learn more</a>
          </div>
        </div>
      </div>
      <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-[#DBDFE2] hover:shadow-md transition-shadow">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/P2462/images/242637.jpg" alt="Dog boarding in Stockport" loading="lazy" width="250" height="187" class="w-full h-full object-cover" />
        </div>
        <div class="p-6">
          <h3 class="text-xl font-800 font-display text-[#12283C] mb-2">🛏️ Dog Boarding</h3>
          <p class="text-[#0B1824] text-sm mb-4">Your dog stays with us as part of the family. Currently only available to existing walking or day care clients.</p>
          <div class="flex items-center justify-between">
            <span class="text-[#12283C] font-semibold text-sm">£23.00 per night</span>
            <a href="/P2462/dog-boarding-html" class="text-[#12283C] font-semibold text-sm underline hover:text-yellow-600">Learn more</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Coverage Area -->
  <section class="bg-[#ECEEEF] py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-800 font-display text-[#12283C] mb-4">My Coverage Area</h2>
      <p class="text-[#0B1824] text-lg mb-8">I serve the 4 Heatons and surrounding areas of Stockport.</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl p-4 shadow-sm border border-[#DBDFE2]">
          <div class="text-2xl mb-2">🗺️</div>
          <div class="font-semibold text-[#12283C] text-sm">Heaton Mersey</div>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm border border-[#DBDFE2]">
          <div class="text-2xl mb-2">🗺️</div>
          <div class="font-semibold text-[#12283C] text-sm">Heaton Chapel</div>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm border border-[#DBDFE2]">
          <div class="text-2xl mb-2">🗺️</div>
          <div class="font-semibold text-[#12283C] text-sm">Heaton Moor</div>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm border border-[#DBDFE2]">
          <div class="text-2xl mb-2">🗺️</div>
          <div class="font-semibold text-[#12283C] text-sm">Heaton Norris</div>
        </div>
      </div>
      <p class="mt-6 text-[#0B1824] text-sm">Also covering surrounding Stockport areas. <a href="/P2462/contact-us-html" class="text-[#12283C] underline font-semibold">Get in touch</a> to check if I cover your area.</p>
    </div>
  </section>

  <!-- Gallery -->
  <section class="py-16 px-4 max-w-6xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl font-800 font-display text-[#12283C] mb-3">Some of My Happy Customers</h2>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      <div class="aspect-square overflow-hidden rounded-xl">
        <img src="/P2462/images/215874-orig.jpg" alt="Happy dog" loading="lazy" width="640" height="480" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
      </div>
      <div class="aspect-square overflow-hidden rounded-xl">
        <img src="/P2462/images/4523039-orig.jpg" alt="Dog on a walk" loading="lazy" width="640" height="480" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
      </div>
      <div class="aspect-square overflow-hidden rounded-xl">
        <img src="/P2462/images/5940847-orig.jpg" alt="Dog enjoying the outdoors" loading="lazy" width="640" height="480" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
      </div>
      <div class="aspect-square overflow-hidden rounded-xl">
        <img src="/P2462/images/100754-orig.jpg" alt="Dog walking in Stockport" loading="lazy" width="640" height="480" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
      </div>
      <div class="aspect-square overflow-hidden rounded-xl">
        <img src="/P2462/images/3481723-orig.jpg" alt="Dog out for a walk" loading="lazy" width="640" height="480" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
      </div>
      <div class="aspect-square overflow-hidden rounded-xl">
        <img src="/P2462/images/5995670-orig.jpg" alt="Happy customers" loading="lazy" width="640" height="480" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
      </div>
    </div>
  </section>

  <!-- Pricing Summary -->
  <section class="bg-[#12283C] text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-800 font-display text-center mb-10 text-white">Simple, Clear Charges</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white/10 rounded-2xl p-6 text-center border border-white/20">
          <div class="text-3xl mb-3">🐕</div>
          <h3 class="font-800 font-display text-xl mb-2 text-white">Dog Walking</h3>
          <div class="text-3xl font-800 text-yellow-400 mb-1">£10</div>
          <div class="text-white/70 text-sm mb-3">Group walk (min 1 hour)</div>
          <div class="text-2xl font-800 text-yellow-400 mb-1">£13</div>
          <div class="text-white/70 text-sm">Single walk (min 1 hour)</div>
        </div>
        <div class="bg-white/10 rounded-2xl p-6 text-center border border-white/20">
          <div class="text-3xl mb-3">🏠</div>
          <h3 class="font-800 font-display text-xl mb-2 text-white">Dog Boarding</h3>
          <div class="text-3xl font-800 text-yellow-400 mb-1">£23</div>
          <div class="text-white/70 text-sm mb-3">Per 24-hour period</div>
          <div class="text-white/70 text-sm">Includes min 2 walks per day</div>
        </div>
        <div class="bg-white/10 rounded-2xl p-6 text-center border border-white/20">
          <div class="text-3xl mb-3">🚗</div>
          <h3 class="font-800 font-display text-xl mb-2 text-white">Pets to Vets</h3>
          <div class="text-3xl font-800 text-yellow-400 mb-1">£7.50</div>
          <div class="text-white/70 text-sm mb-3">Plus £0.50 per mile</div>
          <div class="text-white/70 text-sm">If vet is over 5 miles away</div>
        </div>
      </div>
      <div class="text-center mt-8">
        <p class="text-white/80 text-sm mb-4">Collection and drop off is free. Discounts available for regular dog walks.</p>
        <a href="/P2462/charges-html" class="inline-block bg-yellow-400 text-[#12283C] font-semibold px-8 py-3 rounded-full hover:bg-yellow-300 transition-colors">View Full Charges</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-4 text-center max-w-2xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-800 font-display text-[#12283C] mb-4">Ready to Book?</h2>
    <p class="text-[#0B1824] text-lg mb-8">Get in touch to discuss your requirements and find out how I can help you and your dog.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="tel:01614328807" class="bg-[#12283C] text-white font-semibold px-8 py-3 rounded-full hover:bg-[#0E2030] transition-colors">📞 0161 432 8807</a>
      <a href="/P2462/contact-us-html" class="bg-yellow-400 text-[#12283C] font-semibold px-8 py-3 rounded-full hover:bg-yellow-300 transition-colors">Send a Message</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-[#0E2030] text-white py-12 px-4">
    <div class="max-w-6xl mx-auto grid md:grid-cols-4 gap-8">
      <div>
        <div class="font-display font-800 text-xl mb-3">🐾 Alfies Pet Services</div>
        <address class="not-italic text-white/70 text-sm leading-relaxed">
          38 Sunnybank Avenue<br />
          Heaton Mersey<br />
          Stockport SK4 3PR
        </address>
        <div class="mt-3 text-sm">
          <a href="tel:01614328807" class="text-yellow-400 hover:text-yellow-300 block">0161 432 8807</a>
          <a href="tel:07902384948" class="text-yellow-400 hover:text-yellow-300 block">07902 384948</a>
          <a href="mailto:Alfiespetservices@sky.com" class="text-yellow-400 hover:text-yellow-300 block break-all">Alfiespetservices@sky.com</a>
        </div>
      </div>
      <div>
        <h4 class="font-display font-800 text-sm uppercase tracking-wide text-white/50 mb-3">Services</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/P2462/dog-walking-html" class="hover:text-white transition-colors">Dog Walking</a></li>
          <li><a href="/P2462/doggie-day-care-html" class="hover:text-white transition-colors">Doggie Day Care</a></li>
          <li><a href="/P2462/dog-boarding-html" class="hover:text-white transition-colors">Dog Boarding</a></li>
          <li><a href="/P2462/charges-html" class="hover:text-white transition-colors">Charges</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-display font-800 text-sm uppercase tracking-wide text-white/50 mb-3">Info</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/P2462/about-us-html" class="hover:text-white transition-colors">About Me</a></li>
          <li><a href="/P2462/contact-us-html" class="hover:text-white transition-colors">Contact Us</a></li>
          <li><a href="/P2462/terms-and-conditions-html" class="hover:text-white transition-colors">Terms &amp; Conditions</a></li>
          <li><a href="/P2462/customer-page-html" class="hover:text-white transition-colors">Customer Page</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-display font-800 text-sm uppercase tracking-wide text-white/50 mb-3">More</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/P2462/blog-html" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/P2462/dogs-needing-a-homelost-dogs---can-you-help-html" class="hover:text-white transition-colors">Dogs Needing a Home</a></li>
          <li><a href="/P2462/greyhounds-in-need-html" class="hover:text-white transition-colors">Greyhounds in Need</a></li>
        </ul>
      </div>
    </div>
    <div class="max-w-6xl mx-auto mt-8 pt-6 border-t border-white/10 text-center text-white/40 text-xs">
      &copy; {new Date().getFullYear()} Alfies Pet Services. This is a sample site built by <a href="https://biscuitweb.co.uk" class="underline hover:text-white/70">Biscuit Web</a>.
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  </script>

</body>
</html>
