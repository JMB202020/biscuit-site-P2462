---
import '../styles/site.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Charges | Alfies Pet Services | Stockport</title>
  <meta name="description" content="Clear, simple charges for dog walking, doggie day care and dog boarding in Stockport. Alfies Pet Services." />
</head>
<body>

  <!-- Preview Banner -->
    <div style="background:#B45309;color:white;padding:10px 16px;text-align:center;font-size:14px;position:sticky;top:0;z-index:50"><div style="max-width:56rem;margin:0 auto;display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap"><span>Preview redesign for <strong>Alfies Pet Services</strong></span><a href="https://biscuitweb.co.uk/activate?id=P2462&amp;name=Alfies%20Pet%20Services" style="display:inline-flex;align-items:center;padding:4px 16px;background:white;color:#B45309;font-weight:700;font-size:12px;border-radius:9999px;text-decoration:none">Like it? Just £20/month</a></div></div>

    <div class="border border-[#DBDFE2] rounded-xl p-4">
          <div class="text-sm font-semibold text-[#0B1824] uppercase tracking-wide mb-1">Single Walk</div>
          <div class="text-3xl font-800 text-[#12283C]">£13.00</div>
          <div class="text-sm text-[#0B1824] mt-1">Minimum 1 hour</div>
        </div>
      </div>
      <div class="mt-4 space-y-1 text-sm text-[#0B1824]">
        <p>Longer or shorter walks are available upon request.</p>
        <p>Collection and drop off of your dog is free of charge and is not included in the minimum dog walk time.</p>
        <p>Discounts are available for regular dog walks.</p>
        <p>Puppies are accepted at no extra charge to the above rates.</p>
      </div>
    </div>

    <!-- Dog Boarding -->
    <div class="bg-white rounded-2xl p-8 shadow-sm border border-[#DBDFE2] mb-6">
      <h2 class="text-2xl font-800 font-display text-[#12283C] mb-6">🛏️ Dog Boarding</h2>
      <div class="border border-[#DBDFE2] rounded-xl p-4 inline-block mb-4">
        <div class="text-sm font-semibold text-[#0B1824] uppercase tracking-wide mb-1">Per 24-hour period (or part thereof)</div>
        <div class="text-3xl font-800 text-[#12283C]">£23.00</div>
      </div>
      <div class="space-y-1 text-sm text-[#0B1824]">
        <p>Boarding fee includes a minimum of 2 walks per day. Additional walks may be given at the discretion of Alfie's Pet Services at no extra charge.</p>
        <p>Additional walks as requested by the owner will be charged at <strong>£5.00</strong> per additional walk (minimum 1 hour).</p>
      </div>
    </div>

    <!-- Pets to Vets -->
    <div class="bg-white rounded-2xl p-8 shadow-sm border border-[#DBDFE2] mb-6">
      <h2 class="text-2xl font-800 font-display text-[#12283C] mb-6">🚗 Pets to Vets</h2>
      <div class="border border-[#DBDFE2] rounded-xl p-4 inline-block mb-4">
        <div class="text-sm font-semibold text-[#0B1824] uppercase tracking-wide mb-1">Vet visit during boarding stay</div>
        <div class="text-3xl font-800 text-[#12283C]">£7.50 <span class="text-lg font-semibold">+ £0.50/mile</span></div>
      </div>
      <div class="space-y-1 text-sm text-[#0B1824]">
        <p>Mileage fee only applies if your vet is over 5 miles from Heaton Mersey.</p>
        <p>In these instances, Alfie's Pet Services cannot pay vet fees on your behalf. Arrangements will need to be made with your vet regarding payment of treatment prior to your dog's stay.</p>
      </div>
    </div>

    <!-- Payment -->
    <div class="bg-[#ECEEEF] rounded-2xl p-6 mb-8">
      <h3 class="font-800 font-display text-[#12283C] text-lg mb-3">Payment</h3>
      <ul class="space-y-2 text-sm text-[#0B1824]">
        <li class="flex items-start gap-2"><span class="text-[#12283C]">•</span> All accounts are to be settled by cash or credit card via PayPal on or before the day the dog leaves the accommodation.</li>
        <li class="flex items-start gap-2"><span class="text-[#12283C]">•</span> Alfie's Pet Services is not registered for VAT and as such VAT is not charged.</li>
        <li class="flex items-start gap-2"><span class="text-[#12283C]">•</span> Medication prescribed for your pet can in most cases be continued whilst boarding, free of charge. It is the owner's responsibility to ensure the correct medication is provided and clear instructions are given.</li>
      </ul>
    </div>

    <div class="text-center">
      <a href="/P2462/contact-us-html" class="inline-block bg-yellow-400 text-[#12283C] font-semibold px-8 py-3 rounded-full hover:bg-yellow-300 transition-colors">Get in Touch</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-[#0E2030] text-white py-12 px-4">
    <div class="max-w-6xl mx-auto grid md:grid-cols-4 gap-8">
      <div>
        <div class="font-display font-800 text-xl mb-3">🐾 Alfies Pet Services</div>
        <address class="not-italic text-white/70 text-sm leading-relaxed">
          38 Sunnybank Avenue<br />Heaton Mersey<br />Stockport SK4 3PR
        </address>
        <div class="mt-3 text-sm">
          <a href="tel:01614328807" class="text-yellow-400 hover:text-yellow-300 block">0161 432 8807</a>
          <a href="tel:07902384948" class="text-yellow-400 hover:text-yellow-300 block">07902 384948</a>
          <a href="mailto:Alfiespetservices@sky.com" class="text-yellow-400 hover:text-yellow-300 block break-all">Alfiespetservices@sky.com</a>
        </div>
      </div>
      <div>
        <h4 class="font-display font-800 text-sm uppercase tracking-wide text-white/50 mb-3">Services</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/P2462/dog-walking-html" class="hover:text-white">Dog Walking</a></li>
          <li><a href="/P2462/doggie-day-care-html" class="hover:text-white">Doggie Day Care</a></li>
          <li><a href="/P2462/dog-boarding-html" class="hover:text-white">Dog Boarding</a></li>
          <li><a href="/P2462/charges-html" class="hover:text-white">Charges</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-display font-800 text-sm uppercase tracking-wide text-white/50 mb-3">Info</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/P2462/about-us-html" class="hover:text-white">About Me</a></li>
          <li><a href="/P2462/contact-us-html" class="hover:text-white">Contact Us</a></li>
          <li><a href="/P2462/terms-and-conditions-html" class="hover:text-white">Terms &amp; Conditions</a></li>
          <li><a href="/P2462/customer-page-html" class="hover:text-white">Customer Page</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-display font-800 text-sm uppercase tracking-wide text-white/50 mb-3">More</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/P2462/blog-html" class="hover:text-white">Blog</a></li>
          <li><a href="/P2462/dogs-needing-a-homelost-dogs---can-you-help-html" class="hover:text-white">Dogs Needing a Home</a></li>
          <li><a href="/P2462/greyhounds-in-need-html" class="hover:text-white">Greyhounds in Need</a></li>
        </ul>
      </div>
    </div>
    <div class="max-w-6xl mx-auto mt-8 pt-6 border-t border-white/10 text-center text-white/40 text-xs">
      &copy; {new Date().getFullYear()} Alfies Pet Services. This is a sample site built by <a href="https://biscuitweb.co.uk" class="underline hover:text-white/70">Biscuit Web</a>.
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => { menu?.classList.toggle('hidden'); });
  </script>
</body>
</html>
