---
import '../styles/site.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dogs Needing a Home / Lost Dogs | Alfies Pet Services | Stockport</title>
  <meta name="description" content="Help find lost dogs or rehome dogs in Stockport. Alfies Pet Services supports the local community during the 4 Heatons walks." />
</head>
<body>

  <!-- Preview Banner -->
  <div class="bg-[#12283C] text-white text-sm text-center py-2 px-4">
    Preview redesign for Alfies Pet Services by <a href="https://biscuitweb.co.uk/activate?id=P2462&name=Alfies%20Pet%20Services" class="underline font-semibold hover:text-yellow-300">Biscuit Web</a>
  </div>

  <!-- Nav -->
  <header class="bg-[#12283C] text-white sticky top-0 z-50 shadow-lg">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
      <a href="/P2462" class="font-display font-800 text-xl tracking-tight">🐾 Alfies Pet Services</a>
      <nav class="hidden md:flex items-center gap-6 text-sm font-semibold">
        <a href="/P2462" class="hover:text-yellow-300 transition-colors">Home</a>
        <a href="/P2462/about-us-html" class="hover:text-yellow-300 transition-colors">About Me</a>
        <a href="/P2462/dog-walking-html" class="hover:text-yellow-300 transition-colors">Dog Walking</a>
        <a href="/P2462/doggie-day-care-html" class="hover:text-yellow-300 transition-colors">Doggie Day Care</a>
        <a href="/P2462/dog-boarding-html" class="hover:text-yellow-300 transition-colors">Dog Boarding</a>
        <a href="/P2462/charges-html" class="hover:text-yellow-300 transition-colors">Charges</a>
        <a href="/P2462/contact-us-html" class="bg-yellow-400 text-[#12283C] px-4 py-2 rounded-full hover:bg-yellow-300 transition-colors">Contact Us</a>
      </nav>
      <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Open menu">
        <span class="block w-6 h-0.5 bg-white"></span>
        <span class="block w-6 h-0.5 bg-white"></span>
        <span class="block w-6 h-0.5 bg-white"></span>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden bg-[#0E2030] px-4 pb-4 flex flex-col gap-3 text-sm font-semibold">
      <a href="/P2462" class="block py-2 border-b border-white/10 hover:text-yellow-300">Home</a>
      <a href="/P2462/about-us-html" class="block py-2 border-b border-white/10 hover:text-yellow-300">About Me</a>
      <a href="/P2462/dog-walking-html" class="block py-2 border-b border-white/10 hover:text-yellow-300">Dog Walking</a>
      <a href="/P2462/doggie-day-care-html" class="block py-2 border-b border-white/10 hover:text-yellow-300">Doggie Day Care</a>
      <a href="/P2462/dog-boarding-html" class="block py-2 border-b border-white/10 hover:text-yellow-300">Dog Boarding</a>
      <a href="/P2462/charges-html" class="block py-2 border-b border-white/10 hover:text-yellow-300">Charges</a>
      <a href="/P2462/contact-us-html" class="block py-2 border-b border-white/10 hover:text-yellow-300">Contact Us</a>
      <a href="/P2462/customer-page-html" class="block py-2 border-b border-white/10 hover:text-yellow-300">Customer Page</a>
      <a href="/P2462/dogs-needing-a-homelost-dogs---can-you-help-html" class="block py-2 border-b border-white/10 text-yellow-400">Dogs Needing a Home</a>
      <a href="/P2462/terms-and-conditions-html" class="block py-2 border-b border-white/10 hover:text-yellow-300">Terms &amp; Conditions</a>
      <a href="/P2462/blog-html" class="block py-2 border-b border-white/10 hover:text-yellow-300">Blog</a>
      <a href="/P2462/greyhounds-in-need-html" class="block py-2 hover:text-yellow-300">Greyhounds in Need</a>
    </div>
  </header>

  <!-- Page Hero -->
  <section class="relative h-48 md:h-64 flex items-center justify-center overflow-hidden">
    <img src="/P2462/images/home-7.jpg" alt="Dogs needing a home in Stockport" fetchpriority="high" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10 text-center text-white px-4 max-w-2xl mx-auto">
      <h1 class="text-2xl md:text-4xl font-800 font-display text-white">Dogs Needing a Home / Lost Dogs</h1>
      <p class="text-white/80 mt-2">Can you help?</p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 px-4 max-w-4xl mx-auto">
    <div class="grid md:grid-cols-2 gap-10">
      <!-- Dogs Needing a Home -->
      <div>
        <h2 class="text-2xl font-800 font-display text-[#12283C] mb-4">🏠 Dogs Needing a Home</h2>
        <p class="text-[#0B1824] leading-relaxed mb-4">
          Have you lost your pet or are you looking to rehome a pet you can no longer care for? To place a free advert on this website, please email a picture of the pet and full details to:
        </p>
        <a href="mailto:Alfiespetservices@sky.com" class="inline-block bg-yellow-400 text-[#12283C] font-semibold px-6 py-2.5 rounded-full hover:bg-yellow-300 transition-colors text-sm mb-6">
          ✉️ Alfiespetservices@sky.com
        </a>
        <p class="text-[#0B1824] text-sm leading-relaxed">
          Adverts are completely free of charge. Include a photo and full details about the pet.
        </p>
      </div>

      <!-- Lost Dogs -->
      <div>
        <h2 class="text-2xl font-800 font-display text-[#12283C] mb-4">🔍 Lost Your Dog?</h2>
        <p class="text-[#0B1824] leading-relaxed mb-4">
          If your pet is lost, we will keep an eye out during our frequent walks in the 4 Heatons area. We appreciate how stressful and worrying it can be when you lose a pet and we want to help wherever we can.
        </p>
        <p class="text-[#0B1824] text-sm mb-3">We also recommend you contact:</p>
        <ul class="space-y-2 text-sm text-[#0B1824]">
          <li class="flex items-start gap-2"><span class="text-[#12283C]">•</span> The Stockport Dog Warden Service</li>
          <li class="flex items-start gap-2"><span class="text-[#12283C]">•</span> Your local police</li>
        </ul>
      </div>
    </div>

    <!-- Advice from Manchester Dog Warden -->
    <div class="bg-[#ECEEEF] rounded-2xl p-6 mt-10">
      <h2 class="text-xl font-800 font-display text-[#12283C] mb-4">Advice from the Manchester Dog Warden Service</h2>
      <p class="text-sm text-[#0B1824] mb-4">If your dog is lost or missing, follow this advice:</p>
      <ul class="space-y-3 text-sm text-[#0B1824]">
        <li class="flex items-start gap-2">
          <span class="text-[#12283C] mt-0.5 font-bold">1.</span>
          <span>Speak to people in your local area and ask if your dog has been seen. A photograph of the dog is helpful.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[#12283C] mt-0.5 font-bold">2.</span>
          <span>Regularly check with the Manchester Dogs' Home to see if your dog has been taken there. All dogs brought in as strays are looked after for 7 full days, after which the dog becomes the property of the Dogs' Home and is put up for adoption.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[#12283C] mt-0.5 font-bold">3.</span>
          <span>Check with the Animal Wardens on a regular basis. They have records of thousands of lost and found dogs on their website.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[#12283C] mt-0.5 font-bold">4.</span>
          <span>Check the DogLost or Petlog websites.</span>
        </li>
      </ul>
    </div>

    <!-- What Dog Wardens Do -->
    <div class="bg-white rounded-2xl p-6 mt-6 shadow-sm border border-[#DBDFE2]">
      <h3 class="font-800 font-display text-[#12283C] text-lg mb-4">What Manchester Dog Wardens Will Do</h3>
      <p class="text-sm text-[#0B1824] leading-relaxed">
        Any dog that is unsupervised in a public place may be taken by them. If the dog has a tag with contact details, or is microchipped, they will try to contact the owner. If the dog cannot be taken straight home it will be taken to Manchester Dogs' Home.
      </p>
    </div>

    <!-- Useful Links -->
    <div class="bg-white rounded-2xl p-6 mt-6 shadow-sm border border-[#DBDFE2]">
      <h3 class="font-800 font-display text-[#12283C] text-lg mb-4">Useful Links</h3>
      <ul class="space-y-2 text-sm">
        <li><a href="http://www.stockport.gov.uk/services/environment/envhealth/animalwelfare/dogwardenservice/" target="_blank" rel="noopener noreferrer" class="text-[#12283C] underline hover:text-yellow-600">Stockport Dog Warden Service</a></li>
        <li><span class="text-[#0B1824]">Manchester Dogs' Home</span></li>
        <li><span class="text-[#0B1824]">Animal Wardens</span></li>
        <li><span class="text-[#0B1824]">DogLost</span></li>
        <li><span class="text-[#0B1824]">Petlog</span></li>
      </ul>
    </div>

    <div class="mt-10 text-center">
      <p class="text-[#0B1824] mb-4">Need help? Get in touch with us directly.</p>
      <a href="/P2462/contact-us-html" class="inline-block bg-yellow-400 text-[#12283C] font-semibold px-8 py-3 rounded-full hover:bg-yellow-300 transition-colors">Contact Us</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-[#0E2030] text-white py-12 px-4">
    <div class="max-w-6xl mx-auto grid md:grid-cols-4 gap-8">
      <div>
        <div class="font-display font-800 text-xl mb-3">🐾 Alfies Pet Services</div>
        <address class="not-italic text-white/70 text-sm leading-relaxed">
          38 Sunnybank Avenue<br />Heaton Mersey<br />Stockport SK4 3PR
        </address>
        <div class="mt-3 text-sm">
          <a href="tel:01614328807" class="text-yellow-400 hover:text-yellow-300 block">0161 432 8807</a>
          <a href="tel:07902384948" class="text-yellow-400 hover:text-yellow-300 block">07902 384948</a>
          <a href="mailto:Alfiespetservices@sky.com" class="text-yellow-400 hover:text-yellow-300 block break-all">Alfiespetservices@sky.com</a>
        </div>
      </div>
      <div>
        <h4 class="font-display font-800 text-sm uppercase tracking-wide text-white/50 mb-3">Services</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/P2462/dog-walking-html" class="hover:text-white">Dog Walking</a></li>
          <li><a href="/P2462/doggie-day-care-html" class="hover:text-white">Doggie Day Care</a></li>
          <li><a href="/P2462/dog-boarding-html" class="hover:text-white">Dog Boarding</a></li>
          <li><a href="/P2462/charges-html" class="hover:text-white">Charges</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-display font-800 text-sm uppercase tracking-wide text-white/50 mb-3">Info</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/P2462/about-us-html" class="hover:text-white">About Me</a></li>
          <li><a href="/P2462/contact-us-html" class="hover:text-white">Contact Us</a></li>
          <li><a href="/P2462/terms-and-conditions-html" class="hover:text-white">Terms &amp; Conditions</a></li>
          <li><a href="/P2462/customer-page-html" class="hover:text-white">Customer Page</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-display font-800 text-sm uppercase tracking-wide text-white/50 mb-3">More</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/P2462/blog-html" class="hover:text-white">Blog</a></li>
          <li><a href="/P2462/dogs-needing-a-homelost-dogs---can-you-help-html" class="hover:text-white">Dogs Needing a Home</a></li>
          <li><a href="/P2462/greyhounds-in-need-html" class="hover:text-white">Greyhounds in Need</a></li>
        </ul>
      </div>
    </div>
    <div class="max-w-6xl mx-auto mt-8 pt-6 border-t border-white/10 text-center text-white/40 text-xs">
      &copy; {new Date().getFullYear()} Alfies Pet Services. This is a sample site built by <a href="https://biscuitweb.co.uk" class="underline hover:text-white/70">Biscuit Web</a>.
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => { menu?.classList.toggle('hidden'); });
  </script>
</body>
</html>
