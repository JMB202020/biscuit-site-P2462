---
import '../styles/site.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us | Alfies Pet Services | Stockport</title>
  <meta name="description" content="Contact Alfies Pet Services in Stockport. Tel: 0161 432 8807. 38 Sunnybank Avenue, Heaton Mersey, Stockport SK4 3PR." />
</head>
<body>

  <!-- Preview Banner -->
    <div style="background:#B45309;color:white;padding:10px 16px;text-align:center;font-size:14px;position:sticky;top:0;z-index:50"><div style="max-width:56rem;margin:0 auto;display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap"><span>Preview redesign for <strong>Alfies Pet Services</strong></span><a href="https://biscuitweb.co.uk/activate?id=P2462&amp;name=Alfies%20Pet%20Services" style="display:inline-flex;align-items:center;padding:4px 16px;background:white;color:#B45309;font-weight:700;font-size:12px;border-radius:9999px;text-decoration:none">Like it? Just £20/month</a></div></div>

    <div class="flex items-start gap-4">
            <div class="text-2xl mt-0.5">📞</div>
            <div>
              <div class="font-semibold text-[#12283C] mb-1">Phone</div>
              <a href="tel:01614328807" class="text-[#12283C] hover:text-yellow-600 font-medium block">Tel: 0161 432 8807</a>
              <a href="tel:07902384948" class="text-[#12283C] hover:text-yellow-600 font-medium block">Mobile: 07902 384948</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="text-2xl mt-0.5">✉️</div>
            <div>
              <div class="font-semibold text-[#12283C] mb-1">Email</div>
              <a href="mailto:Alfiespetservices@sky.com" class="text-[#12283C] hover:text-yellow-600 font-medium break-all">Alfiespetservices@sky.com</a>
            </div>
          </div>
        </div>

        <div class="mt-8 bg-[#ECEEEF] rounded-2xl p-6">
          <h3 class="font-800 font-display text-[#12283C] text-lg mb-3">Coverage Area</h3>
          <p class="text-sm text-[#0B1824]">I serve the 4 Heatons and surrounding areas of Stockport: Heaton Mersey, Heaton Chapel, Heaton Moor and Heaton Norris.</p>
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <h2 class="text-2xl font-800 font-display text-[#12283C] mb-6">Send a Message</h2>
        <form action="https://formspree.io/f/mwvaaojq" method="POST" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-semibold text-[#12283C] mb-1">Your Name</label>
            <input type="text" id="name" name="name" required class="w-full border border-[#B8BFC5] rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-[#12283C] bg-white" placeholder="Jane Smith" />
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-[#12283C] mb-1">Email Address</label>
            <input type="email" id="email" name="email" required class="w-full border border-[#B8BFC5] rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-[#12283C] bg-white" placeholder="jane@example.com" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-semibold text-[#12283C] mb-1">Phone Number</label>
            <input type="tel" id="phone" name="phone" class="w-full border border-[#B8BFC5] rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-[#12283C] bg-white" placeholder="07700 900000" />
          </div>
          <div>
            <label for="service" class="block text-sm font-semibold text-[#12283C] mb-1">Service Required</label>
            <select id="service" name="service" class="w-full border border-[#B8BFC5] rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-[#12283C] bg-white">
              <option value="">Please select...</option>
              <option value="Dog Walking">Dog Walking</option>
              <option value="Doggie Day Care">Doggie Day Care</option>
              <option value="Dog Boarding">Dog Boarding</option>
              <option value="Pets to Vets">Pets to Vets</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-semibold text-[#12283C] mb-1">Message</label>
            <textarea id="message" name="message" rows="5" required class="w-full border border-[#B8BFC5] rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-[#12283C] bg-white resize-none" placeholder="Tell me about your dog and what you need..."></textarea>
          </div>
          <button type="submit" class="w-full bg-[#12283C] text-white font-semibold py-3 rounded-full hover:bg-[#0E2030] transition-colors">Send Message</button>
        </form>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-[#0E2030] text-white py-12 px-4">
    <div class="max-w-6xl mx-auto grid md:grid-cols-4 gap-8">
      <div>
        <div class="font-display font-800 text-xl mb-3">🐾 Alfies Pet Services</div>
        <address class="not-italic text-white/70 text-sm leading-relaxed">
          38 Sunnybank Avenue<br />Heaton Mersey<br />Stockport SK4 3PR
        </address>
        <div class="mt-3 text-sm">
          <a href="tel:01614328807" class="text-yellow-400 hover:text-yellow-300 block">0161 432 8807</a>
          <a href="tel:07902384948" class="text-yellow-400 hover:text-yellow-300 block">07902 384948</a>
          <a href="mailto:Alfiespetservices@sky.com" class="text-yellow-400 hover:text-yellow-300 block break-all">Alfiespetservices@sky.com</a>
        </div>
      </div>
      <div>
        <h4 class="font-display font-800 text-sm uppercase tracking-wide text-white/50 mb-3">Services</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/P2462/dog-walking-html" class="hover:text-white">Dog Walking</a></li>
          <li><a href="/P2462/doggie-day-care-html" class="hover:text-white">Doggie Day Care</a></li>
          <li><a href="/P2462/dog-boarding-html" class="hover:text-white">Dog Boarding</a></li>
          <li><a href="/P2462/charges-html" class="hover:text-white">Charges</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-display font-800 text-sm uppercase tracking-wide text-white/50 mb-3">Info</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/P2462/about-us-html" class="hover:text-white">About Me</a></li>
          <li><a href="/P2462/contact-us-html" class="hover:text-white">Contact Us</a></li>
          <li><a href="/P2462/terms-and-conditions-html" class="hover:text-white">Terms &amp; Conditions</a></li>
          <li><a href="/P2462/customer-page-html" class="hover:text-white">Customer Page</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-display font-800 text-sm uppercase tracking-wide text-white/50 mb-3">More</h4>
        <ul class="space-y-2 text-sm text-white/70">
          <li><a href="/P2462/blog-html" class="hover:text-white">Blog</a></li>
          <li><a href="/P2462/dogs-needing-a-homelost-dogs---can-you-help-html" class="hover:text-white">Dogs Needing a Home</a></li>
          <li><a href="/P2462/greyhounds-in-need-html" class="hover:text-white">Greyhounds in Need</a></li>
        </ul>
      </div>
    </div>
    <div class="max-w-6xl mx-auto mt-8 pt-6 border-t border-white/10 text-center text-white/40 text-xs">
      &copy; {new Date().getFullYear()} Alfies Pet Services. This is a sample site built by <a href="https://biscuitweb.co.uk" class="underline hover:text-white/70">Biscuit Web</a>.
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => { menu?.classList.toggle('hidden'); });
  </script>
</body>
</html>
